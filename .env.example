# SiteSignal — environment variables template
# Copy this file to .env and fill in the values. Never commit .env.

# --- Database ---
# libpq URI. Format: postgresql://user:password@host:port/dbname[?options]
#
# Local Postgres:
#   DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/sentinel2_brownfield
#
# Supabase (append ?sslmode=require to force TLS):
#   DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# --- Copernicus Data Space (Sentinel-2 API) ---
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
